# Discord bot token from the Developer Portal (this is a second, separate bot)
DISCORD_TOKEN=your-bot-token-here

# Optional
OWNER_ID=000000000000000000
COMMAND_PREFIX=!
MAX_CHARS=300
DEFAULT_VOICE=en-US-AriaNeural

# SQLite by default; the path is inside the mounted data volume in Docker
DATABASE_URL=sqlite+aiosqlite:///data/tts.sqlite3
